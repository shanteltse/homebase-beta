{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "ANTHROPIC_API_KEY",
        "CRON_SECRET",
        "NODE_ENV",
        "NEXTAUTH_URL",
        "AUTH_URL",
        "RESEND_API_KEY"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "ANTHROPIC_API_KEY",
        "CRON_SECRET",
        "NODE_ENV",
        "NEXTAUTH_URL",
        "AUTH_URL"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "ANTHROPIC_API_KEY",
        "CRON_SECRET",
        "NODE_ENV",
        "NEXTAUTH_URL",
        "AUTH_URL"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
