# Neon Postgres — use the connection string from your Neon branch
# prod: main branch | dev: dev branch | ci: ci branch
DATABASE_URL=""

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Anthropic (optional, for AI features)
ANTHROPIC_API_KEY=""

# Resend — for sending household invite emails
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sending address (must match a domain verified in your Resend account)
# Leave unset to use Resend's shared test sender (onboarding@resend.dev)
EMAIL_FROM=""
