{
  "name": "homebase-beta",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "fmt": "prettier --write \"**/*.{ts,tsx,md,json,css,mjs}\"",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,md,json,css,mjs}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
